graph TB
  subgraph Database["Database"]
    subgraph Primary["Primary"]
      Master["Master"]
      Replica["Replica"]
      Master -->|replication| Replica
    end
    ConnPool["Connection Pool"]
    ConnPool --> Master
    ConnPool --> Replica
  end

  subgraph CacheLayer["Cache"]
    Redis["Redis"]
    InMemory["In-Memory L1"]
    InMemory -->|miss| Redis
  end

  App["Application"] --> ConnPool
  App --> InMemory
