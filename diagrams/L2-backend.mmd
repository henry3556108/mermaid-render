graph TB
  subgraph Gateway["API Gateway"]
    RateLimiter["Rate Limiter"]
    Router["Router"]
    RateLimiter --> Router
  end

  subgraph AuthService["Auth Service"]
    subgraph TokenMgmt["Token"]
      JWT["JWT Manager"]
      Refresh["Refresh Handler"]
      JWT --> Refresh
    end
    OAuth["OAuth"]
    OAuth --> JWT
  end

  subgraph UserSvc["User Service"]
    UserCRUD["CRUD"]
    Profile["Profile"]
    Profile --> UserCRUD
  end

  Router --> AuthService
  Router --> UserSvc
  AuthService --> Cache[("Redis")]
  UserSvc --> DB[("PostgreSQL")]
